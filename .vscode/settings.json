{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "deno.enable": false,
  "deno.enablePaths": [
    "packages/server",
    "packages/sdk",
    "packages/ai-sdk",
    "packages/cli"
  ],
  "deno.lint": true,
  "deno.unstable": [],
  "deno.suggest.imports.hosts": {
    "https://deno.land": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true
  }
}
