{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Worlds Docs",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/images/wazoo.svg",
  "colors": {
    "primary": "#D97706",
    "light": "#F59E0B",
    "dark": "#78350F"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Worlds Docs",
      "canonical": "https://docs.wazoo.dev"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-V64G870T6Z"
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/wazootech/worlds"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Console",
      "href": "https://console.wazoo.dev"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": [
          "worlds/index",
          "overview/getting-started/quickstart",
          "overview/architecture",
          "overview/features",
          "overview/philosophy-history",
          "overview/whitepaper",
          "overview/roadmap"
        ]
      },
      {
        "group": "Worlds",
        "pages": [
          "worlds/items",
          "worlds/facts",
          "worlds/search",
          "worlds/query",
          "worlds/update",
          "worlds/logs"
        ]
      },
      {
        "group": "Platform",
        "pages": [
          "platform/overview",
          "platform/cli",
          "platform/sdk",
          "platform/api"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/self-hosting",
          "guides/automation-vibe-coding",
          "guides/worlds-sdk"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "guides/vercel-ai-sdk",
          "guides/openai-sdk",
          "guides/langgraph",
          "guides/openai-agents-sdk",
          "guides/ms-agent-framework",
          "guides/mastra",
          "guides/langchain",
          "guides/crewai",
          "guides/agno",
          "guides/claude-memory-tool",
          "guides/gemini-api",
          "guides/gemini-live-api",
          "guides/n8n",
          "guides/viasocket",
          "guides/zapier",
          "guides/openclaw",
          "guides/claude-code",
          "guides/opencode",
          "guides/zo"
        ]
      },
      {
        "group": "API Reference",
        "openapi": "openapi.yaml",
        "pages": [
          "reference/index",
          "reference/api-basics/authentication",
          "reference/api",
          "reference/rate-limits",
          "reference/changelog",
          "reference/sdk-overview",
          "reference/sdk",
          "reference/cli"
        ]
      },
      {
        "group": "Contribute",
        "pages": [
          "contribute/contributing-guide",
          "contribute/code-of-conduct",
          "contribute/license",
          "contribute/security"
        ]
      }
    ]
  },
  "footer": {
    "links": [
      {
        "header": "Explore",
        "items": [
          {
            "label": "Worlds Console",
            "href": "https://console.wazoo.dev"
          },
          {
            "label": "SDK (JSR)",
            "href": "https://jsr.io/@wazoo/worlds-sdk"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/wazootech/worlds"
          },
          {
            "label": "X (Twitter)",
            "href": "https://x.com/wazootech"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "Blog",
            "href": "https://wazoo.dev/blog"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/worlds/index"
    }
  ]
}
