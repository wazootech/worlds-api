{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Worlds Docs",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/images/wazoo.svg",
  "colors": {
    "primary": "#D97706",
    "light": "#F59E0B",
    "dark": "#78350F"
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Worlds Docs",
      "canonical": "https://docs.wazoo.dev"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-V64G870T6Z"
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/wazootech/worlds"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Console",
      "href": "https://console.wazoo.dev"
    }
  },
  "navigation": {
    "products": [
      {
        "product": "Worlds",
        "groups": [
          {
            "group": "Worlds",
            "pages": [
              "worlds/index",
              "worlds/search",
              "worlds/query",
              "worlds/update"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/overview"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "overview/getting-started/quickstart",
              "guides/self-host"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "guides/ai-sdk",
              "guides/claude-code",
              "guides/gemini-api",
              "guides/mastra",
              "guides/n8n",
              "guides/openclaw",
              "guides/opencode",
              "guides/openai-sdk",
              "guides/zapier",
              "guides/zo"
            ]
          },
          {
            "group": "Contribute",
            "pages": [
              "contribute/contributing-guide",
              "contribute/code-of-conduct",
              "contribute/license",
              "contribute/security",
              "contribute/changelog"
            ]
          }
        ],
        "icon": "globe"
      },
      {
        "product": "Worlds CLI",
        "groups": [
          {
            "group": "Worlds CLI",
            "pages": [
              "reference/cli/index"
            ]
          },
          {
            "group": "Subcommands",
            "pages": [
              "reference/cli/create",
              "reference/cli/get",
              "reference/cli/list",
              "reference/cli/update",
              "reference/cli/import",
              "reference/cli/export",
              "reference/cli/search",
              "reference/cli/sparql",
              "reference/cli/delete",
              "reference/cli/chat"
            ]
          }
        ],
        "icon": "terminal"
      },
      {
        "product": "Worlds API",
        "groups": [
          {
            "group": "HTTP REST API",
            "openapi": "openapi.yaml",
            "pages": [
              "reference/index"
            ]
          }
        ],
        "icon": "code"
      }
    ]
  },
  "footer": {
    "links": [
      {
        "header": "Explore",
        "items": [
          {
            "label": "Worlds Console",
            "href": "https://console.wazoo.dev"
          },
          {
            "label": "SDK (JSR)",
            "href": "https://jsr.io/@wazoo/worlds-sdk"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/wazootech/worlds"
          },
          {
            "label": "X (Twitter)",
            "href": "https://x.com/wazootech"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "Blog",
            "href": "https://wazoo.dev/blog"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/worlds"
    }
  ],
  "icons": {
    "library": "lucide"
  },
  "anchors": [
    {
      "icon": "terminal",
      "name": "Worlds CLI",
      "url": "reference/cli/index"
    },
    {
      "icon": "code",
      "name": "Worlds API",
      "url": "reference/index"
    }
  ]
}
