{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Worlds Docs",
  "colors": {
    "primary": "#D97706",
    "light": "#F59E0B",
    "dark": "#78350F"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "favicon": "/images/wazoo.svg",
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Worlds Docs",
      "canonical": "https://docs.wazoo.dev"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Developer Platform",
        "icon": "code",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "intro",
              {
                "group": "Quickstart",
                "root": "quickstart",
                "pages": ["quickstart/cli", "quickstart/sdk"]
              }
            ]
          },
          {
            "group": "Concepts",
            "pages": ["concepts/worlds", "concepts/graphs", "concepts/search"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "book-open",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "Endpoints",
            "pages": [
              "GET /worlds",
              "POST /worlds",
              "GET /worlds/{world}",
              "PUT /worlds/{world}",
              "DELETE /worlds/{world}",
              "GET /worlds/{world}/search",
              "GET /worlds/{world}/sparql",
              "POST /worlds/{world}/sparql",
              "GET /worlds/{world}/logs",
              "GET /worlds/{world}/export",
              "POST /worlds/{world}/import"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Console",
          "href": "https://console.wazoo.dev",
          "icon": "globe"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/overview",
      "destination": "/intro"
    }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/wazootech/worlds"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Console",
      "href": "https://console.wazoo.dev"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Explore",
        "items": [
          {
            "label": "Worlds Console",
            "href": "https://console.wazoo.dev"
          },
          {
            "label": "SDK (JSR)",
            "href": "https://jsr.io/@wazoo/worlds-sdk"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/wazootech/worlds"
          },
          {
            "label": "X (Twitter)",
            "href": "https://x.com/wazootech"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "Blog",
            "href": "https://wazoo.dev/blog"
          }
        ]
      }
    ]
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-V64G870T6Z"
    }
  }
}
