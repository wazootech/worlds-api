{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Worlds Docs",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "favicon": "/images/wazoo.svg",
  "colors": {
    "primary": "#FF9800",
    "light": "#FFB74D",
    "dark": "#F57C00"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "body": {
      "family": "Geist"
    },
    "heading": {
      "family": "IBM Plex Mono"
    }
  },
  "background": {
    "color": {
      "light": "#fafaf9",
      "dark": "#040404"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Worlds Docs",
      "canonical": "https://docs.wazoo.dev"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-V64G870T6Z"
    }
  },
  "api": {
    "params": {
      "expanded": "all"
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/wazootech/worlds"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Console",
      "href": "https://console.wazoo.dev"
    }
  },
  "navigation": {
    "products": [
      {
        "product": "Worlds",
        "icon": "globe",
        "groups": [
          {
            "group": "Welcome",
            "pages": ["introduction", "quickstart", "platform", "manifesto"]
          },
          {
            "group": "Worlds",
            "pages": [
              "worlds/index",
              "worlds/search",
              "worlds/query",
              "worlds/update"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "guides/ai-sdk",
              "guides/claude-code",
              "guides/gemini-api",
              "guides/mastra",
              "guides/n8n",
              "guides/openclaw",
              "guides/opencode",
              "guides/openai",
              "guides/zapier",
              "guides/zo"
            ]
          },
          {
            "group": "Open Source",
            "pages": [
              "contribute/architecture",
              "guides/self-host",
              "contribute/security",
              "contribute/index",
              "contribute/coc",
              "contribute/license"
            ]
          }
        ]
      },
      {
        "product": "Worlds API",
        "icon": "code",
        "groups": [
          {
            "group": "Worlds API",
            "pages": ["reference/index"]
          },
          {
            "group": "API Reference",
            "openapi": "openapi.yaml",
            "pages": [
              "GET /worlds",
              "POST /worlds",
              "GET /worlds/{world}",
              "PUT /worlds/{world}",
              "DELETE /worlds/{world}",
              "GET /worlds/{world}/export",
              "POST /worlds/{world}/import",
              "GET /worlds/{world}/logs",
              "GET /worlds/{world}/search",
              "GET /worlds/{world}/sparql",
              "POST /worlds/{world}/sparql"
            ]
          }
        ]
      },
      {
        "product": "Worlds CLI",
        "icon": "terminal",
        "groups": [
          {
            "group": "Worlds CLI",
            "pages": ["reference/cli/index"]
          },
          {
            "group": "CLI Reference",
            "icon": "terminal",
            "pages": [
              "reference/cli/create",
              "reference/cli/get",
              "reference/cli/list",
              "reference/cli/update",
              "reference/cli/import",
              "reference/cli/export",
              "reference/cli/search",
              "reference/cli/sparql",
              "reference/cli/delete",
              "reference/cli/chat"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "links": [
      {
        "header": "Developers",
        "items": [
          {
            "label": "API Reference",
            "href": "/reference"
          },
          {
            "label": "CLI Reference",
            "href": "/reference/cli"
          },
          {
            "label": "SDK (JSR)",
            "href": "https://jsr.io/@wazoo/worlds-sdk"
          }
        ]
      },
      {
        "header": "Explore",
        "items": [
          {
            "label": "Worlds Console",
            "href": "https://console.wazoo.dev"
          },
          {
            "label": "Blog",
            "href": "https://wazoo.dev/blog"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/wazootech/worlds"
          },
          {
            "label": "X (Twitter)",
            "href": "https://x.com/wazootech"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/introduction"
    }
  ],
  "icons": {
    "library": "lucide"
  }
}
