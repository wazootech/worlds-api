{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Worlds Docs",
  "colors": {
    "primary": "#D97706",
    "light": "#F59E0B",
    "dark": "#78350F"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
  },
  "favicon": "/images/wazoo.svg",
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:type": "website",
      "og:site_name": "Worlds Docs",
      "canonical": "https://docs.wazoo.dev"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Developer Platform",
        "icon": "code",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["overview", "quickstart", "vibe-coding"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/how-it-works",
              "concepts/worlds-vs-rag",
              "concepts/knowledge-primitives",
              "concepts/agentic-loop",
              "concepts/reasoning-inference"
            ]
          },
          {
            "group": "Infrastructure",
            "pages": [
              "infrastructure/philosophy",
              "infrastructure/deployment",
              "infrastructure/configuration",
              "infrastructure/whitepaper"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/system-design",
              "architecture/request-pipeline"
            ]
          }
        ]
      },
      {
        "tab": "API Integrations",
        "icon": "plug",
        "groups": [
          {
            "group": "Native SDKs",
            "pages": [
              "api-integrations/native-sdks/index",
              "api-integrations/native-sdks/sdk"
            ]
          },
          {
            "group": "Frameworks",
            "pages": [
              "api-integrations/frameworks/ai-sdk",
              "api-integrations/frameworks/vercel-ai",
              "api-integrations/frameworks/langchain",
              "api-integrations/frameworks/openai"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "book-open",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "API Basics",
            "pages": [
              "api-reference/basics/authentication",
              "api-reference/basics/search",
              "api-reference/basics/sparql",
              "api-reference/basics/specification"
            ]
          },
          {
            "group": "Endpoints",
            "expanded": false,
            "pages": [
              "GET /worlds",
              "POST /worlds",
              "GET /worlds/{world}",
              "PUT /worlds/{world}",
              "DELETE /worlds/{world}",
              "GET /worlds/{world}/search",
              "GET /worlds/{world}/sparql",
              "POST /worlds/{world}/sparql",
              "GET /worlds/{world}/logs",
              "GET /worlds/{world}/export",
              "POST /worlds/{world}/import"
            ]
          }
        ]
      },
      {
        "tab": "Cookbook",
        "icon": "hat-chef",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "cookbook/guides/social-graphs",
              "cookbook/guides/personal-search",
              "cookbook/guides/cli-tasks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Console",
          "href": "https://console.wazoo.dev",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
