{
  "tasks": {
    "dev": "deno run --watch main.ts",
    "generate": "deno run -A src/openapi/openapi.ts && deno fmt ./src/openapi/generated"
  },
  "imports": {
    "#/": "./src/",
    "@hey-api/openapi-ts": "npm:@hey-api/openapi-ts@^0.96.1",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "openapi-types": "npm:openapi-types@^12.1.3",
    "zod": "npm:zod@^4.3.6"
  },
  "lint": {
    "exclude": [
      "./src/openapi/generated",
      "./src/worlds/types.gen.ts"
    ]
  }
}
