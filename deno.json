{
  "name": "@worlds/worlds-api",
  "version": "0.0.1",
  "nodeModulesDir": "auto",
  "imports": {
    "#/": "./src/",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.2.1",
    "@hey-api/openapi-ts": "npm:@hey-api/openapi-ts@^0.97.0",
    "@hono/hono": "npm:hono@^4.12.16",
    "@libsql/client": "npm:@libsql/client@^0.17.3",
    "@orama/orama": "npm:@orama/orama@^3.1.18",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "hono": "npm:hono@^4.12.16",
    "n3": "npm:n3@^2.0.3",
    "openapi-types": "npm:openapi-types@^12.1.3",
    "rdf-canonize": "npm:rdf-canonize@^5.0.0",
    "zod": "npm:zod@^4.4.2"
  },
  "links": [
    "./vendor/jsonld-context-parser"
  ],
  "tasks": {
    "dev": "deno serve --watch main.ts",
    "serve": "deno serve main.ts",
    "bundle:browser": "deno bundle --no-check --platform=browser src/rdf/rdf.ts; deno bundle --no-check --platform=browser src/rdf/sparql/sparql.ts",
    "test": "deno test --allow-all",
    "generate": "deno run -A src/rpc/openapi/openapi.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./rdf": "./src/rdf/rdf.ts",
    "./sparql": "./src/rdf/sparql/sparql.ts",
    "./indexing": "./src/indexing/mod.ts"
  },
  "fmt": {
    "exclude": [
      "src/rpc/openapi/generated/**"
    ]
  },
  "lint": {
    "exclude": [
      "src/rpc/openapi/generated/**",
      "vendor/jsonld-context-parser/**"
    ],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["require-await"]
    }
  },
  "exclude": ["vendor/**"]
}
